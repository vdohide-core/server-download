# MongoDB Connection URI
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/platform

# Storage settings (optional — uses DB storage if not set)
# STORAGE_ID=your-storage-uuid
# STORAGE_PATH=/home/files

# Worker ID (optional — defaults to hostname@1)
# WORKER_ID=worker-1

# Scraper URL (optional — for HLS scraping)
# SCRAPER_URL=http://localhost:8081
